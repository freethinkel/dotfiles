{
  "context_servers": {
    "mcp-server-gitlab": {
      "source": "extension",
      "settings": {
        "gitlab_personal_access_token": "",
        "gitlab_api_url": "https://ci.unitedline.net/api/v4"
      }
    }
  },
  "debugger": {
    "dock": "left"
  },
  "icon_theme": "Zed (Default)",
  "private_files": ["*.g.dart"],
  "agent": {
    "profiles": {
      "ask": {
        "name": "Ask",
        "tools": {
          "contents": true,
          "diagnostics": true,
          "fetch": true,
          "list_directory": true,
          "now": true,
          "find_path": true,
          "read_file": true,
          "open": true,
          "grep": true,
          "thinking": true,
          "web_search": true
        },
        "enable_all_context_servers": false,
        "context_servers": {
          "mcp-server-gitlab": {
            "tools": {
              "search_repositories": true,
              "push_files": true,
              "get_file_contents": true,
              "fork_repository": true,
              "create_repository": true,
              "create_or_update_file": true,
              "create_merge_request": true,
              "create_issue": true,
              "create_branch": true
            }
          }
        }
      },
      "gitlab": {
        "name": "Gitlab",
        "tools": {
          "thinking": true,
          "terminal": true,
          "read_file": true,
          "open": true,
          "grep": true
        },
        "enable_all_context_servers": false,
        "context_servers": {
          "mcp-server-gitlab": {
            "tools": {
              "create_branch": true,
              "create_issue": true,
              "create_merge_request": true,
              "create_repository": true,
              "fork_repository": true,
              "get_file_contents": true,
              "create_or_update_file": true,
              "push_files": true,
              "search_repositories": true
            }
          }
        }
      }
    },
    "single_file_review": true,
    "always_allow_tool_actions": true,
    "default_profile": "ask",
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-sonnet-4"
    }
  },
  "snippet_sort_order": "top",
  "ssh_connections": [
    {
      "host": "kolesnikov.thv04.voiso.dev",
      "username": "app",
      "port": 1355,
      "projects": [
        {
          "paths": ["~/web"]
        }
      ]
    },
    {
      "host": "146.190.151.114",
      "username": "root",
      "projects": [
        {
          "paths": ["~/pocketbackend"]
        }
      ]
    },
    {
      "host": "65.109.123.174",
      "username": "root",
      "port": 1355,
      "projects": []
    }
  ],
  "preview_tabs": {
    "enable_preview_from_code_navigation": true
  },
  "show_completions_on_input": true,
  "git_panel": {
    "enable": true
  },
  "edit_predictions": {
    "enabled_in_text_threads": true,
    "mode": "eager"
  },
  "diagnostics": {
    "include_warnings": true,
    "inline": {
      "enabled": true,
      "update_debounce_ms": 150,
      "padding": 5
    }
  },
  "enable_language_server": true,
  "vim_mode": true,
  "buffer_font_fallbacks": ["FiraCode Nerd Font"],
  "ui_font_fallbacks": ["FiraCode Nerd Font"],
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "ui_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 12.5,
  "ui_font_size": 15,
  "buffer_line_height": {
    "custom": 1.6
  },
  "features": {
    "edit_prediction_provider": "zed"
  },
  "tab_size": 2,
  "vim": {
    "use_system_clipboard": "always"
  },
  "theme": {
    "dark": "Snowfall dark",
    "light": "Gruvbox Light Hard",
    "mode": "system"
  },
  "format_on_save": "on",
  "auto_update": true,
  "inlay_hints": {
    "enabled": false
  },
  "terminal": {
    "env": {
      "GIT_EDITOR": "zed --preview --wait"
    }
  },
  "lsp": {
    "deno": {
      "root": "deno.json",
      "filetypes": ["typescript"]
    },
    "biome": {
      "root": "package.json",
      "enabled": false,
      "filetypes": ["typescript"]
    }
  },
  "languages": {
    "Rust": {
      "formatter": "language_server"
    },
    "CSS": {
      "formatter": "prettier"
    },
    "Lua": {
      "formatter": "language_server"
    },
    "Prisma": {
      "format_on_save": "on",
      "formatter": "language_server"
    },
    "Dart": {
      "formatter": "language_server",
      "language_servers": ["dart", "cspell"],
      "format_on_save": "on",
      "code_actions_on_format": {
        "source.organizeImports": true
      }
    },
    "Svelte": {
      "format_on_save": "on",
      "formatter": "language_server"
    },
    "JavaScript": {
      "formatter": "prettier",
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "TypeScript": {
      "formatter": "prettier",
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    },
    "TSX": {
      "formatter": "prettier",
      "code_actions_on_format": {
        "source.fixAll.eslint": true
      }
    }
  },
  "relative_line_numbers": true,
  "show_whitespaces": "selection",
  "file_types": {
    "CSS": ["pcss"],
    "JSON": ["arb"],
    "XML": ["entitlements"]
  },
  "prettier": {
    "allowed": true
  }
}
