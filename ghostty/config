app-notifications = no-clipboard-copy

font-family = "TX-02-Variable" 
font-family-bold = "TX-02-Variable" 
font-family-italic = "TX-02-Variable" 
font-family-bold-italic = "TX-02-Variable" 
font-size = 12.5
# Common axes are: `wght` (weight), `slnt` (slant), `ital` (italic), `opsz`
# (optical size), `wdth` (width), `GRAD` (gradient), etc.
# font-variation = wght=900

adjust-cell-width = 0%
adjust-cell-height = 50%
adjust-underline-position = 20%
adjust-underline-thickness = -1
adjust-cursor-thickness = 2
adjust-cursor-height = 29%

window-vsync = true

# Shell Integration
shell-integration = zsh
shell-integration-features = cursor,sudo,title

# Shaders
# custom-shader-animation=always
# custom-shader = shaders/bloom.glsl
# custom-shader = shaders/glitchy.glsl
# custom-shader = shaders/just_snow.glsl
# custom-shader = shaders/cursor_blaze.glsl
# custom-shader = shaders/cursor_smear_fade.glsl
custom-shader = shaders/cursor_smear.glsl
# custom-shader = shaders/blur_crt.glsl


# Mouse
mouse-hide-while-typing = true
mouse-scroll-multiplier = 2

# Theme
# macos-icon-custom-style = ghostty
window-theme = system 
macos-icon = custom
macos-custom-icon = /Users/freethinkel/.config/ghostty/nord.icns

cursor-style = bar
background-blur-radius = 40
background-opacity = 1

# macos-titlebar-style = hidden
macos-titlebar-style = tabs

window-colorspace = display-p3
window-step-resize = true 
window-inherit-working-directory = true 
window-padding-color = background
window-save-state = always

theme = light:Nord Light,dark:SnowfallDark
# unfocused-split-fill = #373c44
# split-divider-color = #84c4df

desktop-notifications = true
clipboard-paste-protection = false

# config-file = style.ghostty
config-file = keybind.ghostty
config-file = vim.ghostty

# vim: ft=ghostty
