font-family = "FiraCode Nerd Font" 
font-family-bold = "FiraCode Nerd Font" 
font-family-italic = "FiraCode Nerd Font" 
font-family-bold-italic = "FiraCode Nerd Font" 
font-size = 12.5
# Common axes are: `wght` (weight), `slnt` (slant), `ital` (italic), `opsz`
# (optical size), `wdth` (width), `GRAD` (gradient), etc.
# font-variation = wght=900

adjust-cell-width = 0%
adjust-cell-height = 50%
adjust-underline-position = 20%
adjust-underline-thickness = 0
adjust-cursor-thickness = 2
adjust-cursor-height = 29%

shell-integration-features = cursor, sudo, title
window-vsync = true

# custom-shader = shaders/bloom.glsl
# custom-shader = shaders/glitchy.glsl
# custom-shader = shaders/just_snow.glsl
# custom-shader = shaders/cursor_blaze.glsl
# custom-shader = shaders/cursor_smear_fade.glsl
custom-shader = shaders/cursor_smear.glsl

# Mouse
mouse-hide-while-typing = true
mouse-scroll-multiplier = 2

# Theme
window-theme = system 
# macos-icon = xray
# macos-icon-ghost-color = #fcbfcb
# macos-icon-screen-color = #fbbfbb

cursor-style = bar
background-blur-radius = 40
background-opacity = 1

# macos-titlebar-style = hidden
macos-titlebar-style = tabs

window-colorspace = display-p3
window-step-resize = true 
window-inherit-working-directory = true 
window-padding-color = background

theme = light:Ayu Light,dark:SnowfallDark
unfocused-split-fill = #373c44
split-divider-color = #84c4df

desktop-notifications = true
clipboard-paste-protection = false

# Mapping 
macos-option-as-alt = true

keybind = cmd+right=text:\x05
keybind = cmd+left=text:\x01
keybind = alt+left=esc:b
keybind = alt+right=esc:f

# keybind = clear
## TMUX
keybind = super+option+minus=text:\x02\x22
keybind = super+j=text:\x02\x22
keybind = super+option+backslash=text:\x02\x25
keybind = super+shift+right_bracket=text:\x02\x6e
keybind = super+shift+left_bracket=text:\x02\x70
keybind = super+t=text:\x02\x63
keybind = super+x=text:\x02\x78
keybind = super+w=text:\x02\x78
keybind = super+comma=text:\x02\x2c

keybind = super+option+i=inspector:toggle

keybind = global:cmd+grave_accent=toggle_quick_terminal
# keybind = global:ctrl+enter=toggle_quick_terminal

